generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////
/// ENUMS
////////////////////

enum Language {
  es
  en
}

enum Mood {
  calm
  stressed
  confident
  neutral
}

enum TransactionType {
  expense
  income
}

enum EmotionTag {
  need
  impulse
  emotional
}

enum HabitFrequency {
  daily
  weekly
}

enum InvestmentStrategy {
  conservative
  balanced
  long_term
}

enum RoleType {
  super_admin
  admin
  support
  user
}

enum SubscriptionStatus {
  trial
  active
  expired
  cancelled
}

enum GroupMemberRole {
  owner
  member
}

////////////////////
/// MODELS
////////////////////

model AppConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("app_config")
}

model Role {
  id          String           @id @default(uuid())
  name        RoleType         @unique
  description String?
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  action      String           @unique
  description String?
  createdAt   DateTime         @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  isActive            Boolean             @default(true)
  language            Language            @default(es)
  timezone            String
  onboardingCompleted Boolean             @default(false)
  createdAt           DateTime            @default(now())

  roleId              String?
  role                Role?               @relation(fields: [roleId], references: [id])

  person              Person?
  dailySnapshots      DailySnapshot[]
  transactions        Transaction[]
  accounts            Account[]
  habits              Habit[]
  savingGoals         SavingGoal[]
  investmentProfiles  InvestmentProfile[]
  passwordResetTokens PasswordResetToken[]
  subscription        Subscription?
  categories          Category[]
  groupsCreated       Group[]             @relation("GroupCreator")
  groupMemberships    GroupMember[]
  groupExpensesPaid   GroupExpense[]      @relation("GroupExpensePayer")
  budgets                Budget[]
  recurringTransactions  RecurringTransaction[]
  pushTokens             PushToken[]

  @@map("users")
}

model Person {
  id          String    @id @default(uuid())
  userId      String    @unique
  firstName   String
  lastName    String
  phone       String?
  birthDate   DateTime?
  country     String?
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])

  @@map("persons")
}

model DailySnapshot {
  id             String        @id @default(uuid())
  userId         String
  date           DateTime
  mood           Mood?
  reflection     String?
  consciousScore Int?
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id])
  transactions   Transaction[]

  @@unique([userId, date])
  @@map("daily_snapshots")
}

model Account {
  id             String        @id @default(uuid())
  userId         String
  name           String
  type           String
  initialBalance Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("USD")
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@map("accounts")
}

model Transaction {
  id                  String              @id @default(uuid())
  userId              String
  dailySnapshotId     String?
  accountId           String?
  amount              Decimal
  type                TransactionType
  emotionTag          EmotionTag?
  note                String?
  occurredAt          DateTime
  createdAt           DateTime            @default(now())

  user                User                @relation(fields: [userId], references: [id])
  dailySnapshot       DailySnapshot?      @relation(fields: [dailySnapshotId], references: [id])
  category            Category?           @relation(fields: [categoryId], references: [id])
  categoryId          String?
  account             Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  groupExpenseShare   GroupExpenseShare?
  images              TransactionImage[]

  @@map("transactions")
}

model TransactionImage {
  id            String      @id @default(uuid())
  transactionId String
  url           String
  publicId      String
  createdAt     DateTime    @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_images")
}

model Category {
  id           String          @id @default(uuid())
  userId       String?
  name         String
  icon         String?
  type         TransactionType
  isSystem     Boolean         @default(false)
  deletedAt    DateTime?

  user                  User?                  @relation(fields: [userId], references: [id])
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  @@map("categories")
}

model Budget {
  id         String   @id @default(uuid())
  userId     String
  categoryId String?
  amount     Decimal  @db.Decimal(12, 2)
  month      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, categoryId, month])
  @@map("budgets")
}

model RecurringTransaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  categoryId  String?
  note        String?
  emotionTag  EmotionTag?
  frequency   String          // 'daily' | 'weekly' | 'monthly' | 'yearly'
  startDate   String          // 'YYYY-MM-DD'
  endDate     String?         // 'YYYY-MM-DD'
  nextRunDate String          // 'YYYY-MM-DD'
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("recurring_transactions")
}

model Habit {
  id        String         @id @default(uuid())
  userId    String
  name      String
  frequency HabitFrequency
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  user      User           @relation(fields: [userId], references: [id])
  logs      HabitLog[]

  @@map("habits")
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime
  completed Boolean
  createdAt DateTime @default(now())

  habit     Habit    @relation(fields: [habitId], references: [id])

  @@unique([habitId, date])
  @@map("habit_logs")
}

model SavingGoal {
  id            String    @id @default(uuid())
  userId        String
  name          String
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])

  @@map("saving_goals")
}

model InvestmentProfile {
  id             String             @id @default(uuid())
  userId         String
  strategy       InvestmentStrategy
  monthlyAmount  Decimal
  expectedReturn Decimal
  createdAt      DateTime           @default(now())

  user           User               @relation(fields: [userId], references: [id])

  @@map("investment_profiles")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model SubscriptionPlan {
  id           String         @id @default(uuid())
  name         String
  description  String?
  priceAmount  Decimal
  currency     String         @default("USD")
  intervalDays Int            @default(30)
  isActive     Boolean        @default(true)
  stripePriceId String?
  createdAt    DateTime       @default(now())

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  planId               String
  status               SubscriptionStatus @default(trial)
  trialEndsAt          DateTime
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  discountPercent      Decimal            @default(0)
  cancelledAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id])
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Group {
  id        String        @id @default(uuid())
  name      String
  createdBy String
  createdAt DateTime      @default(now())
  deletedAt DateTime?

  creator   User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members   GroupMember[]
  expenses  GroupExpense[]

  @@map("groups")
}

model GroupMember {
  id         String          @id @default(uuid())
  groupId    String
  userId     String
  role       GroupMemberRole @default(member)
  percentage Decimal         @default(0) @db.Decimal(5, 2)
  joinedAt   DateTime        @default(now())

  group    Group           @relation(fields: [groupId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  shares   GroupExpenseShare[]

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupExpense {
  id          String             @id @default(uuid())
  groupId     String
  paidById    String
  amount      Decimal
  description String
  occurredAt  DateTime
  createdAt   DateTime           @default(now())

  group       Group              @relation(fields: [groupId], references: [id])
  paidBy      User               @relation("GroupExpensePayer", fields: [paidById], references: [id])
  shares      GroupExpenseShare[]

  @@map("group_expenses")
}

model GroupExpenseShare {
  id                String       @id @default(uuid())
  groupExpenseId    String
  groupMemberId     String
  amount            Decimal
  includeInPersonal Boolean      @default(false)
  transactionId     String?      @unique

  groupExpense      GroupExpense @relation(fields: [groupExpenseId], references: [id])
  groupMember       GroupMember  @relation(fields: [groupMemberId], references: [id])
  transaction       Transaction? @relation(fields: [transactionId], references: [id])

  @@map("group_expense_shares")
}
