NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=pulso
POSTGRES_PASSWORD=pulso_secret
POSTGRES_DB=pulso_db
DB_PORT=5432

DATABASE_URL="postgresql://pulso:pulso_secret@localhost:5432/pulso_db"

# JWT
JWT_SECRET=your_super_secret_key_min_16_chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# Email — Gmail API OAuth2 (producción, usa HTTPS no SMTP)
GMAIL_USER=your_email@gmail.com
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Email — Resend (alternativa, https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM="Pulso App <no-reply@yourdomain.com>"

# SMTP (Nodemailer — solo dev local)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Pulso App <no-reply@pulso.app>"

# Frontend
FRONTEND_URL=http://localhost:5173

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
