NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=pulso
POSTGRES_PASSWORD=pulso_secret
POSTGRES_DB=pulso_db
DB_PORT=5432

DATABASE_URL="postgresql://pulso:pulso_secret@localhost:5432/pulso_db"

# JWT
JWT_SECRET=your_super_secret_key_min_16_chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Pulso App <no-reply@pulso.app>"

# Frontend
FRONTEND_URL=http://localhost:5173
