NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=pulso
POSTGRES_PASSWORD=pulso_secret
POSTGRES_DB=pulso_db
DB_PORT=5432

DATABASE_URL="postgresql://pulso:pulso_secret@localhost:5432/pulso_db"

# JWT
JWT_SECRET=your_super_secret_key_min_16_chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379
